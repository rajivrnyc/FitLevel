<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="24dp">

    <TextView
        android:id="@+id/textAboutTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="About"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/textGroupNameAbout"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/textGroupNameAbout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Team 12"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#BDBDBD"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/textAboutTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/textMembers" />

    <TextView
        android:id="@+id/textMembers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Member 1: Sandy\nMember 2: PUT_NAME\nMember 3: PUT_NAME\nMember 4: PUT_NAME"
        android:textSize="18sp"
        android:textColor="#9E9E9E"
        android:lineSpacingExtra="8dp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/textGroupNameAbout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>