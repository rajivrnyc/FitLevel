<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardForecast"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Day Name (e.g., "Saturday") -->
        <TextView
            android:id="@+id/tvDayName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Saturday"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivWeatherIcon"
            android:layout_marginEnd="12dp" />

        <!-- Date (e.g., "Feb 14") -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#757575"
            android:maxLines="1"
            tools:text="Feb 14"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDayName"
            app:layout_constraintEnd_toStartOf="@id/ivWeatherIcon"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp" />

        <!-- Weather Icon (Center) -->
        <ImageView
            android:id="@+id/ivWeatherIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="Weather condition icon"
            android:scaleType="fitCenter"
            tools:src="@drawable/ic_weather_sunny"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- High Temperature -->
        <TextView
            android:id="@+id/tvTempHigh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FF5722"
            tools:text="35°F"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvTempSeparator" />

        <!-- Temperature Separator -->
        <TextView
            android:id="@+id/tvTempSeparator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="/"
            android:textSize="16sp"
            android:textColor="#757575"
            android:layout_marginHorizontal="4dp"
            app:layout_constraintEnd_toStartOf="@id/tvTempLow"
            app:layout_constraintTop_toTopOf="@id/tvTempHigh"
            app:layout_constraintBottom_toBottomOf="@id/tvTempHigh" />

        <!-- Low Temperature -->
        <TextView
            android:id="@+id/tvTempLow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#2196F3"
            tools:text="28°F"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvTempHigh"
            app:layout_constraintBottom_toBottomOf="@id/tvTempHigh" />

        <!-- Precipitation Icon -->
        <ImageView
            android:id="@+id/ivPrecipIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_precipitation"
            android:contentDescription="Precipitation"
            app:tint="#42A5F5"
            app:layout_constraintEnd_toStartOf="@id/tvPrecipitation"
            app:layout_constraintTop_toTopOf="@id/tvPrecipitation"
            app:layout_constraintBottom_toBottomOf="@id/tvPrecipitation"
            android:layout_marginEnd="4dp" />

        <!-- Precipitation Amount -->
        <TextView
            android:id="@+id/tvPrecipitation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#42A5F5"
            tools:text="0 mm"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTempHigh"
            android:layout_marginTop="4dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>